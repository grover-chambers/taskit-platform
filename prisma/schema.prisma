generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  email         String    @unique
  password      String?
  name          String?
  phone         String?   @unique
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  riderDetail          RiderDetail?
  customerOrders       Order[]              @relation("CustomerOrders")
  riderOrders          Order[]              @relation("RiderOrders")
  shops                Shop[]               @relation("VendorShops")
  serviceProvider      ServiceProvider?
  reviewsGiven         Review[]             @relation("ReviewAuthor")
  reviewsReceived      Review[]             @relation("ReviewTarget")
  notifications        Notification[]
  enterpriseClients    EnterpriseClient[]
  bookings             Booking[]            @relation("BookingCustomer")
  enterpriseDeliveries EnterpriseDelivery[] @relation("EnterpriseRider")
  supportTickets       SupportTicket[]      @relation("TicketCustomer")
  riderTickets         SupportTicket[]
  assignedTickets      SupportTicket[]      @relation("TicketAssignee")
  supportMessages      SupportMessage[]     @relation("MessageSender")

  @@map("users")
}

enum Role {
  CUSTOMER
  VENDOR
  RIDER
  ADMIN

  @@map("user_role")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── RIDER ──
model RiderDetail {
  id            String   @id
  licenseNumber String   @unique
  plateNumber   String   @unique
  kycStatus     String   @default("PENDING")
  rating        Float    @default(5.0)
  isOnline             Boolean  @default(false)
  locationEnabled      Boolean  @default(true)
  notificationsEnabled Boolean  @default(true)
  currentOrderId       String?
  totalTrips           Int      @default(0)
  todayEarnings        Int      @default(0)
  vehicleType          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user      User            @relation(fields: [id], references: [id], onDelete: Cascade)
  earnings  RiderEarning[]
  location  RiderLocation?
  documents RiderDocument[]

  @@map("rider_details")
}

model RiderDocument {
  id         String   @id @default(cuid())
  riderId    String
  docType    String
  url        String
  status     String   @default("PENDING")
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime @default(now())

  rider RiderDetail @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([riderId, docType])
  @@map("rider_documents")
}

model RiderLocation {
  id         String   @id @default(cuid())
  riderId    String   @unique
  lat        Decimal  @db.Decimal(10, 7)
  lng        Decimal  @db.Decimal(10, 7)
  heading    Decimal? @db.Decimal(5, 2)
  speedKmh   Decimal? @db.Decimal(5, 2)
  accuracyM  Decimal? @db.Decimal(6, 2)
  orderId    String?
  updatedAt  DateTime @default(now()) @updatedAt

  rider RiderDetail @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("rider_locations")
}

model RiderEarning {
  id        String   @id @default(cuid())
  riderId   String
  amount    Int
  orderId   String   @unique
  createdAt DateTime @default(now())

  rider RiderDetail @relation(fields: [riderId], references: [id], onDelete: Cascade)
  order Order       @relation(fields: [orderId], references: [id])

  @@map("rider_earnings")
}

// ── VENDOR / SHOP ──
model Shop {
  id          String   @id @default(cuid())
  name        String
  description String?
  location    String?
  phone       String?
  category    String?
  isOpen      Boolean  @default(true)
  rating      Float    @default(0.0)
  totalOrders Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendorId String
  vendor   User      @relation("VendorShops", fields: [vendorId], references: [id])
  products Product[]
  orders   Order[]

  @@map("shops")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int
  image       String?
  category    String?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  @@map("products")
}

// ── SERVICE PROVIDER ──
model ServiceProvider {
  id         String   @id @default(cuid())
  title      String?
  bio        String?
  category   String   @default("GENERAL")
  verified   Boolean  @default(false)
  rating     Float    @default(0.0)
  totalJobs  Int      @default(0)
  hourlyRate Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("service_providers")
}

model Booking {
  id          String    @id @default(cuid())
  description String?
  scheduledAt DateTime?
  status      String    @default("PENDING") // PENDING, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED
  deposit     Int       @default(0)
  balance     Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customerId String
  providerId String
  customer   User            @relation("BookingCustomer", fields: [customerId], references: [id])
  provider   ServiceProvider @relation(fields: [providerId], references: [id])

  @@map("bookings")
}

// ── ZONE / ERRAND TYPE ──
model Zone {
  id        String   @id @default(cuid())
  name      String   @unique
  price     Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@map("zones")
}

model ErrandType {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("errand_types")
}

// ── ORDER ──
model Order {
  id                   String   @id @default(cuid())
  orderType            String   @default("ERRAND")
  errandDescription    String
  pickupLocation       String?
  dropoffLocation      String?
  contactPhone         String?
  specialInstructions  String?
  urgency              String   @default("NORMAL")
  status               String   @default("RECEIVED")
  paymentStatus        String   @default("UNPAID")
  paymentMethod        String   @default("M-PESA")
  mpesaTransactionCode String?  @unique
  mpesaReceipt         String?  @unique
  totalAmount          Int      @default(0)
  isLaaS               Boolean  @default(false)
  idempotencyKey       String?  @unique
  deliveryOtp          String?
  assignedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  customerId String
  riderId    String?
  zoneId     String
  shopId     String?
  vendorId   String?

  customer           User                @relation("CustomerOrders", fields: [customerId], references: [id])
  rider              User?               @relation("RiderOrders", fields: [riderId], references: [id])
  zone               Zone                @relation(fields: [zoneId], references: [id])
  shop               Shop?               @relation(fields: [shopId], references: [id])
  orderItems         OrderItem[]
  statusLogs         OrderStatus[]
  reviews            Review[]
  riderEarning       RiderEarning?
  enterpriseDelivery EnterpriseDelivery?
  supportTickets     SupportTicket[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  quantity  Int    @default(1)
  unitPrice Int

  orderId   String
  productId String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderStatus {
  id        String   @id @default(cuid())
  status    String
  note      String?
  createdAt DateTime @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_logs")
}

// ── REVIEW ──
model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  orderId    String
  authorId   String
  targetId   String
  targetRole String // VENDOR, RIDER, PROVIDER

  order  Order @relation(fields: [orderId], references: [id])
  author User  @relation("ReviewAuthor", fields: [authorId], references: [id])
  target User  @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([orderId, authorId, targetId])
  @@map("reviews")
}

// ── ENTERPRISE (LaaS) ──
model EnterpriseClient {
  id        String   @id @default(cuid())
  name      String
  apiKey    String   @unique
  contact   String?
  rate      Int      @default(120) // per-delivery rate
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId    String
  owner      User                 @relation(fields: [ownerId], references: [id])
  deliveries EnterpriseDelivery[]

  @@map("enterprise_clients")
}

model EnterpriseDelivery {
  id          String   @id @default(cuid())
  reference   String?
  pickup      String
  dropoff     String
  description String?
  status      String   @default("PENDING") // PENDING, ASSIGNED, PICKED_UP, DELIVERED, FAILED
  proofUrl    String?
  slaMinutes  Int?
  breached    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientId String
  orderId  String? @unique
  riderId  String?

  client EnterpriseClient @relation(fields: [clientId], references: [id])
  order  Order?           @relation(fields: [orderId], references: [id])
  rider  User?            @relation("EnterpriseRider", fields: [riderId], references: [id])

  @@map("enterprise_deliveries")
}

// ── NOTIFICATION ──
model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  type      String   @default("INFO") // INFO, ORDER, PAYMENT, SYSTEM
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ── SETTINGS ──
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── SUPPORT ──
model SupportTicket {
  id          String   @id @default(cuid())
  subject     String?
  status      String   @default("OPEN")
  priority    String   @default("NORMAL")
  category    String   @default("GENERAL")
  orderId     String?
  customerId  String?
  riderId     String?
  assigneeId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order       Order?          @relation(fields: [orderId], references: [id])
  customer    User?           @relation("TicketCustomer", fields: [customerId], references: [id])
  rider       User?           @relation(fields: [riderId], references: [id])
  assignee    User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  messages    SupportMessage[]

  @@map("support_tickets")
}

model SupportMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String?
  direction   String   @default("OUTBOUND")
  body        String
  mediaUrl    String?
  channel     String   @default("WHATSAPP")
  whatsappId  String?
  createdAt   DateTime @default(now())

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User?         @relation("MessageSender", fields: [senderId], references: [id])

  @@map("support_messages")
}
